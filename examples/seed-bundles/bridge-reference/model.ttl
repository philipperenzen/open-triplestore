@prefix ex: <https://example.org/seed-bundles/bridge#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Bridge a owl:Class ;
    rdfs:label "Bridge" .

ex:River a owl:Class ;
    rdfs:label "River" .

ex:crossesRiver a owl:ObjectProperty ;
    rdfs:label "crosses river" ;
    rdfs:domain ex:Bridge ;
    rdfs:range ex:River .

ex:length a owl:DatatypeProperty ;
    rdfs:label "length" ;
    rdfs:domain ex:Bridge ;
    rdfs:range xsd:decimal .
