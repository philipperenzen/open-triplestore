# Digital-twin layer — SOSA/SSN sensors & observations on REAL demo buildings.
#
# Sensors are hosted by real features (sosa:isHostedBy), each making
# sosa:Observations with a sosa:observedProperty, a sosa:resultTime and a
# sosa:hasSimpleResult, about a sosa:hasFeatureOfInterest — the standard W3C/OGC
# SOSA shape for a digital twin overlaid on the linked-building-data topology.
#
# Features of interest:
#   * bag:  — REAL BAG panden from the 3DBAG block (seeded by
#     seed_bag_buildings into …/bag-buildings; deployment-independent IRIs).
#     Pand 0268100000029191 is a 2004 three-storey block (indoor climate +
#     energy); pand 0268100000025440 is an 1876 building whose structure is
#     monitored for tilt — a real preservation use case.
#   * sd:   — the Schependomlaan IFC site root (GUID-stable IRI from the
#     canonical design model; resolves once the IFC seed has run, and dangles
#     harmlessly when IFC seeding is disabled).
#   * v3:   — an authored extruded solid from volumes-3d.ttl.

@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix sosa:    <http://www.w3.org/ns/sosa/> .
@prefix bag:     <https://opentriplestore.org/demo/viewer-3d-demo/bag/> .
@prefix sd:      <https://opentriplestore.org/demo/viewer-3d-demo/building/> .
@prefix v3:      <https://opentriplestore.org/demo/viewer-3d-demo/volumes#> .
@prefix dt:      <https://opentriplestore.org/demo/viewer-3d-demo/twin#> .

# ── Observable properties ──
dt:indoorTemperature a sosa:ObservableProperty ;
    rdfs:label "Indoor temperature"@en .
dt:energyUse a sosa:ObservableProperty ;
    rdfs:label "Electrical energy use"@en .
dt:structuralTilt a sosa:ObservableProperty ;
    rdfs:label "Structural tilt"@en .
dt:occupancy a sosa:ObservableProperty ;
    rdfs:label "Occupancy"@en .

# ── Indoor climate + energy on a real 2004 apartment block (BAG pand) ──
dt:TempSensor01 a sosa:Sensor ;
    rdfs:label "Indoor temperature sensor"@en ;
    sosa:isHostedBy bag:NL.IMBAG.Pand.0268100000029191 ;
    sosa:observes dt:indoorTemperature .

dt:Obs-Temp-01 a sosa:Observation ;
    rdfs:label "Temperature reading (08:15)"@en ;
    sosa:madeBySensor dt:TempSensor01 ;
    sosa:hasFeatureOfInterest bag:NL.IMBAG.Pand.0268100000029191 ;
    sosa:observedProperty dt:indoorTemperature ;
    sosa:resultTime "2026-06-12T08:15:00Z"^^xsd:dateTime ;
    sosa:hasSimpleResult "21.4"^^xsd:double .

dt:Obs-Temp-02 a sosa:Observation ;
    rdfs:label "Temperature reading (12:15)"@en ;
    sosa:madeBySensor dt:TempSensor01 ;
    sosa:hasFeatureOfInterest bag:NL.IMBAG.Pand.0268100000029191 ;
    sosa:observedProperty dt:indoorTemperature ;
    sosa:resultTime "2026-06-12T12:15:00Z"^^xsd:dateTime ;
    sosa:hasSimpleResult "23.1"^^xsd:double .

dt:EnergyMeter01 a sosa:Sensor ;
    rdfs:label "Energy meter"@en ;
    sosa:isHostedBy bag:NL.IMBAG.Pand.0268100000029191 ;
    sosa:observes dt:energyUse .

dt:Obs-Energy-01 a sosa:Observation ;
    rdfs:label "Energy-use reading"@en ;
    sosa:madeBySensor dt:EnergyMeter01 ;
    sosa:hasFeatureOfInterest bag:NL.IMBAG.Pand.0268100000029191 ;
    sosa:observedProperty dt:energyUse ;
    sosa:resultTime "2026-06-12T08:15:00Z"^^xsd:dateTime ;
    sosa:hasSimpleResult "3.8"^^xsd:double .

# ── Structural monitoring of a real 1876 building (BAG pand) ──
dt:TiltSensor01 a sosa:Sensor ;
    rdfs:label "Structural tilt sensor (1876 building)"@en ;
    sosa:isHostedBy bag:NL.IMBAG.Pand.0268100000025440 ;
    sosa:observes dt:structuralTilt .

dt:Obs-Tilt-01 a sosa:Observation ;
    rdfs:label "Tilt reading"@en ;
    sosa:madeBySensor dt:TiltSensor01 ;
    sosa:hasFeatureOfInterest bag:NL.IMBAG.Pand.0268100000025440 ;
    sosa:observedProperty dt:structuralTilt ;
    sosa:resultTime "2026-06-12T08:20:00Z"^^xsd:dateTime ;
    sosa:hasSimpleResult "0.12"^^xsd:double .

# ── Occupancy on the Schependomlaan IFC site (BIM ↔ twin bridge) ──
dt:OccupancySensor01 a sosa:Sensor ;
    rdfs:label "Occupancy sensor (Schependomlaan site)"@en ;
    sosa:isHostedBy sd:20FpTZCqJy2vhVJYtjuIce ;
    sosa:observes dt:occupancy .

dt:Obs-Occupancy-01 a sosa:Observation ;
    rdfs:label "Occupancy count"@en ;
    sosa:madeBySensor dt:OccupancySensor01 ;
    sosa:hasFeatureOfInterest sd:20FpTZCqJy2vhVJYtjuIce ;
    sosa:observedProperty dt:occupancy ;
    sosa:resultTime "2026-06-12T09:00:00Z"^^xsd:dateTime ;
    sosa:hasSimpleResult "12"^^xsd:integer .

# ── A tilt gauge on the authored worked-example solid ──
dt:TiltSensor02 a sosa:Sensor ;
    rdfs:label "Tilt gauge (demo solid)"@en ;
    sosa:isHostedBy v3:BlockA ;
    sosa:observes dt:structuralTilt .

dt:Obs-Tilt-02 a sosa:Observation ;
    rdfs:label "Tilt reading (demo solid)"@en ;
    sosa:madeBySensor dt:TiltSensor02 ;
    sosa:hasFeatureOfInterest v3:BlockA ;
    sosa:observedProperty dt:structuralTilt ;
    sosa:resultTime "2026-06-12T08:20:00Z"^^xsd:dateTime ;
    sosa:hasSimpleResult "0.05"^^xsd:double .
