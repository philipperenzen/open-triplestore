# Buildings & BIM demo — a small neighbourhood of buildings where the 3D model,
# the 2D map and the BOT structure tab all work together, modelled the same way
# as schependomlaan-context.ttl and zones-3dbag.ttl but without the heavy
# per-element web-ifc IFC path.
#
# Three geometry encodings are exercised side by side:
#   * CityJSON LoD2 Solids (parsed client-side, coloured by semantic surface):
#       - /samples/neighbourhood.city.json   (four authored LoD2 buildings, CC0)
#       - /samples/schependomlaan-3dbag.city.json (real 3DBAG LoD2.2 excerpt,
#         © 3DBAG by tudelft3d and 3DGI — CC BY 4.0, https://docs.3dbag.nl/en/copyright/)
#   * native WKT-Z solids (POLYHEDRALSURFACE Z, EPSG:7415) so the 3D engine and
#     the 3D-Tiles pipeline have volumetric data with no external file.
# Every building also carries a plain CRS84 POINT (lon/lat) as its 2D map anchor,
# clustered around 5.834 51.842 near the Schependomlaan site in Nijmegen so the
# map zooms to the cluster rather than the whole world.
#
# BOT topology gives the "structure" tab a real tree to walk: the zone contains
# buildings, and the townhouse is fully decomposed into storeys → spaces and
# elements (walls / doors). Coordinates are WGS84 lon/lat (CRS84, no <crs>
# prefix); the CityJSON files are self-georeferenced (EPSG:7415).

@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix geo:     <http://www.opengis.net/ont/geosparql#> .
@prefix bot:     <https://w3id.org/bot#> .
@prefix omg:     <https://w3id.org/omg#> .
@prefix fog:     <https://w3id.org/fog#> .
@prefix bim:     <https://opentriplestore.org/demo/buildings-bim#> .

# ── The zone: the whole demo neighbourhood ──────────────────────────────────
bim:Neighbourhood a bot:Zone ;
    rdfs:label "Buildings & BIM demo"@en ;
    rdfs:comment "A small neighbourhood of buildings near the Schependomlaan site: four authored LoD2 CityJSON buildings, the real 3DBAG city block, and native WKT-Z solids — with a fully decomposed townhouse (storeys, spaces, elements) for the structure tab."@en ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83400 51.84200)"^^geo:wktLiteral ] ;
    bot:containsElement bim:Townhouse , bim:CornerShop , bim:ApartmentBlock ,
                        bim:OfficeBuilding , bim:BagBlock , bim:WorkshopSolid .

# The whole authored CityJSON model (all four buildings) on the zone itself, so
# selecting the zone shows the full LoD2 neighbourhood in the 3D viewer.
bim:Neighbourhood omg:hasGeometry [ a omg:Geometry ;
        fog:asCityjson "/samples/neighbourhood.city.json"^^xsd:anyURI ] .

# ── Building 1: the townhouse (fully BOT-decomposed) ────────────────────────
bim:Townhouse a bot:Building ;
    rdfs:label "Townhouse (LoD2, fully decomposed)"@en ;
    rdfs:comment "A two-storey residential townhouse — the worked example whose storeys, spaces and elements populate the structure tree."@en ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83395 51.84198)"^^geo:wktLiteral ] ;
    omg:hasGeometry [ a omg:Geometry ;
        fog:asCityjson "/samples/neighbourhood.city.json"^^xsd:anyURI ] ;
    bot:hasStorey bim:TownhouseGround , bim:TownhouseFirst .

# Ground floor → two spaces + two elements.
bim:TownhouseGround a bot:Storey ;
    rdfs:label "Townhouse — ground floor"@en ;
    bot:hasSpace bim:GroundLivingRoom , bim:GroundKitchen ;
    bot:hasElement bim:GroundFrontDoor , bim:GroundPartyWall .

bim:GroundLivingRoom a bot:Space ;
    rdfs:label "Living room (ground floor)"@en .
bim:GroundKitchen a bot:Space ;
    rdfs:label "Kitchen (ground floor)"@en .
bim:GroundFrontDoor a bot:Element ;
    rdfs:label "Front door (ground floor)"@en .
bim:GroundPartyWall a bot:Element ;
    rdfs:label "Party wall (ground floor)"@en .

# First floor → two spaces + one element.
bim:TownhouseFirst a bot:Storey ;
    rdfs:label "Townhouse — first floor"@en ;
    bot:hasSpace bim:FirstBedroom , bim:FirstBathroom ;
    bot:hasElement bim:FirstExteriorWall .

bim:FirstBedroom a bot:Space ;
    rdfs:label "Bedroom (first floor)"@en .
bim:FirstBathroom a bot:Space ;
    rdfs:label "Bathroom (first floor)"@en .
bim:FirstExteriorWall a bot:Element ;
    rdfs:label "Exterior wall (first floor)"@en .

# ── Building 2: the corner shop (one storey, a couple of spaces/elements) ────
bim:CornerShop a bot:Building ;
    rdfs:label "Corner shop (LoD2)"@en ;
    rdfs:comment "A single-storey retail unit beside the townhouse."@en ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83419 51.84198)"^^geo:wktLiteral ] ;
    omg:hasGeometry [ a omg:Geometry ;
        fog:asCityjson "/samples/neighbourhood.city.json"^^xsd:anyURI ] ;
    bot:hasStorey bim:ShopGround .

bim:ShopGround a bot:Storey ;
    rdfs:label "Corner shop — shop floor"@en ;
    bot:hasSpace bim:ShopSalesFloor , bim:ShopStoreroom ;
    bot:hasElement bim:ShopFrontDoor .

bim:ShopSalesFloor a bot:Space ;
    rdfs:label "Sales floor"@en .
bim:ShopStoreroom a bot:Space ;
    rdfs:label "Storeroom"@en .
bim:ShopFrontDoor a bot:Element ;
    rdfs:label "Shop front door"@en .

# ── Building 3: the apartment block (four-storey, CityJSON + WKT-Z solid) ────
bim:ApartmentBlock a bot:Building ;
    rdfs:label "Apartment block (LoD2 + WKT-Z)"@en ;
    rdfs:comment "A four-storey residential block — carries both a CityJSON model and a native volumetric WKT-Z solid."@en ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83390 51.84212)"^^geo:wktLiteral ] ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "<http://www.opengis.net/def/crs/EPSG/0/7415> POLYHEDRALSURFACE Z (((187400 428514 0,187400 428526 0,187416 428526 0,187416 428514 0,187400 428514 0)),((187400 428514 13,187416 428514 13,187416 428526 13,187400 428526 13,187400 428514 13)),((187400 428514 0,187400 428514 13,187400 428526 13,187400 428526 0,187400 428514 0)),((187416 428514 0,187416 428526 0,187416 428526 13,187416 428514 13,187416 428514 0)),((187400 428514 0,187416 428514 0,187416 428514 13,187400 428514 13,187400 428514 0)),((187400 428526 0,187400 428526 13,187416 428526 13,187416 428526 0,187400 428526 0)))"^^geo:wktLiteral ] ;
    omg:hasGeometry [ a omg:Geometry ;
        fog:asCityjson "/samples/neighbourhood.city.json"^^xsd:anyURI ] ;
    bot:hasStorey bim:ApartmentFloor1 , bim:ApartmentFloor2 .

bim:ApartmentFloor1 a bot:Storey ;
    rdfs:label "Apartment block — floor 1"@en ;
    bot:hasSpace bim:ApartmentUnit1A , bim:ApartmentUnit1B .
bim:ApartmentFloor2 a bot:Storey ;
    rdfs:label "Apartment block — floor 2"@en ;
    bot:hasSpace bim:ApartmentUnit2A , bim:ApartmentUnit2B .

bim:ApartmentUnit1A a bot:Space ; rdfs:label "Apartment 1A"@en .
bim:ApartmentUnit1B a bot:Space ; rdfs:label "Apartment 1B"@en .
bim:ApartmentUnit2A a bot:Space ; rdfs:label "Apartment 2A"@en .
bim:ApartmentUnit2B a bot:Space ; rdfs:label "Apartment 2B"@en .

# ── Building 4: the office (two-storey, CityJSON) ───────────────────────────
bim:OfficeBuilding a bot:Building ;
    rdfs:label "Office building (LoD2)"@en ;
    rdfs:comment "A two-storey office at the east of the block."@en ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83423 51.84210)"^^geo:wktLiteral ] ;
    omg:hasGeometry [ a omg:Geometry ;
        fog:asCityjson "/samples/neighbourhood.city.json"^^xsd:anyURI ] ;
    bot:hasStorey bim:OfficeGround , bim:OfficeFirst .

bim:OfficeGround a bot:Storey ;
    rdfs:label "Office — ground floor"@en ;
    bot:hasSpace bim:OfficeReception .
bim:OfficeFirst a bot:Storey ;
    rdfs:label "Office — first floor"@en ;
    bot:hasSpace bim:OfficeOpenPlan .

bim:OfficeReception a bot:Space ; rdfs:label "Reception"@en .
bim:OfficeOpenPlan a bot:Space ; rdfs:label "Open-plan office"@en .

# ── Building 5: the real 3DBAG block, surfaced as a selectable building ──────
bim:BagBlock a bot:Building ;
    rdfs:label "3DBAG city block (LoD2.2)"@en ;
    rdfs:comment "The real 3DBAG LoD2.2 excerpt around the Schependomlaan site, reused as a richly detailed neighbour."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:rightsHolder "© 3DBAG by tudelft3d and 3DGI" ;
    dcterms:source <https://docs.3dbag.nl/en/copyright/> ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83373 51.84114)"^^geo:wktLiteral ] ;
    omg:hasGeometry [ a omg:Geometry ;
        fog:asCityjson "/samples/schependomlaan-3dbag.city.json"^^xsd:anyURI ] .

# ── Building 6: a native WKT-Z workshop (no model file, pure volumetric) ─────
bim:WorkshopSolid a bot:Building ;
    rdfs:label "Workshop (native WKT-Z solid)"@en ;
    rdfs:comment "A 10 m × 15 m × 6 m workshop as a closed POLYHEDRALSURFACE Z — volumetric data for the 3D engine with no external model file."@en ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83432 51.84200)"^^geo:wktLiteral ] ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "<http://www.opengis.net/def/crs/EPSG/0/7415> POLYHEDRALSURFACE Z (((187422 428514 0,187422 428524 0,187434 428524 0,187434 428514 0,187422 428514 0)),((187422 428514 6,187434 428514 6,187434 428524 6,187422 428524 6,187422 428514 6)),((187422 428514 0,187422 428514 6,187422 428524 6,187422 428524 0,187422 428514 0)),((187434 428514 0,187434 428524 0,187434 428524 6,187434 428514 6,187434 428514 0)),((187422 428514 0,187434 428514 0,187434 428514 6,187422 428514 6,187422 428514 0)),((187422 428524 0,187422 428524 6,187434 428524 6,187434 428524 0,187422 428524 0)))"^^geo:wktLiteral ] .
