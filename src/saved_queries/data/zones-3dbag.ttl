# More "zones" — 3DBAG-style city blocks with several building elements.
#
# A second bot:Zone beside the canonical Schependomlaan block, plus per-building
# elements, modelled exactly like schependomlaan-context.ttl: BOT topology
# (bot:Zone bot:containsElement bot:Element), OMG/FOG file references
# (omg:hasGeometry → fog:asCityjson) and a GeoSPARQL geo:asWKT map anchor.
#
# Two CityJSON sources are referenced:
#   * the bundled real 3DBAG LoD2.2 excerpt   /samples/schependomlaan-3dbag.city.json
#     (© 3DBAG by tudelft3d and 3DGI — CC BY 4.0, https://docs.3dbag.nl/en/copyright/)
#   * a small authored second zone            /samples/schependomlaan-zone2.city.json
#     (two LoD2 buildings, CC0) — appropriate real-world sizes (≈ 14 m and 16 m
#     wide, 7–11 m tall), so the trusted CityJSON size path renders them at scale.
#
# Coordinates are WGS84 lon/lat (CRS84, no <crs> prefix); the CityJSON files are
# self-georeferenced (EPSG:7415), the WKT points are the fallback map anchors.

@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix geo:     <http://www.opengis.net/ont/geosparql#> .
@prefix bot:     <https://w3id.org/bot#> .
@prefix omg:     <https://w3id.org/omg#> .
@prefix fog:     <https://w3id.org/fog#> .
@prefix z2:      <https://opentriplestore.org/demo/viewer-3d-demo/zones#> .

# ── Zone 2: a second city block, just south of the Schependomlaan site ──
z2:NeighbourBlock a bot:Zone ;
    rdfs:label "Neighbour city block (LoD2 demo)"@en ;
    rdfs:comment "A second demo block beside the Schependomlaan site: two LoD2 CityJSON buildings."@en ;
    dcterms:license <https://creativecommons.org/publicdomain/zero/1.0/> ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83310 51.84050)"^^geo:wktLiteral ] ;
    bot:containsElement z2:NeighbourHouse , z2:NeighbourShop .

# The whole second-zone CityJSON model (both buildings) on the zone itself.
z2:NeighbourBlock omg:hasGeometry [ a omg:Geometry ;
        fog:asCityjson "/samples/schependomlaan-zone2.city.json"^^xsd:anyURI ] .

z2:NeighbourHouse a bot:Element ;
    rdfs:label "Neighbour house (LoD2)"@en ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83305 51.84048)"^^geo:wktLiteral ] ;
    # This building's own CityObject in the shared zone model (a `#objectId`
    # fragment, like an IFC element's `#GlobalId`): the block renders once and a
    # pick on this house resolves back to this element.
    omg:hasGeometry [ a omg:Geometry ;
        fog:asCityjson "/samples/schependomlaan-zone2.city.json#zone2-house"^^xsd:anyURI ] .

z2:NeighbourShop a bot:Element ;
    rdfs:label "Neighbour shop (LoD2)"@en ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83330 51.84052)"^^geo:wktLiteral ] ;
    omg:hasGeometry [ a omg:Geometry ;
        fog:asCityjson "/samples/schependomlaan-zone2.city.json#zone2-shop"^^xsd:anyURI ] .

# ── A second reference to the real 3DBAG excerpt, as its own zone element so the
#    canonical block and this richer block both appear as selectable "zones". ──
z2:BagBlockEast a bot:Element ;
    rdfs:label "3DBAG block (east, LoD2.2)"@en ;
    rdfs:comment "The real 3DBAG LoD2.2 excerpt, surfaced as a second selectable block."@en ;
    dcterms:license <https://creativecommons.org/licenses/by/4.0/> ;
    dcterms:rightsHolder "© 3DBAG by tudelft3d and 3DGI" ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83430 51.84140)"^^geo:wktLiteral ] ;
    omg:hasGeometry [ a omg:Geometry ;
        fog:asCityjson "/samples/schependomlaan-3dbag.city.json"^^xsd:anyURI ] .

z2:NeighbourBlock bot:containsElement z2:BagBlockEast .
