# Native WKT-Z volumetric geometry — two simple extruded building blocks.
#
# These give the 3D engine (crate::geo::geom3d), the 3D viewer and the 3D-Tiles
# pipeline native volumetric data to show without needing an external model file:
# each block is a closed POLYHEDRALSURFACE Z (the WKT encoding of a CityJSON
# Solid's outer shell — bottom + top + side walls), so area3d / volume / height
# and the 3D index all have real geometry to work on.
#
# Geometry is in EPSG:7415 (RD New + NAP height), the same CRS the bundled 3DBAG
# CityJSON uses — so the metric measures (height, footprint, volume) come out in
# metres at real-world scale near the Schependomlaan site (RD easting ≈ 185673,
# northing ≈ 428054). The volumetric literal carries the <crs> prefix so the
# store records its source CRS; the 2D map path leaves POLYHEDRALSURFACE to the
# 3D engine, so each block also carries a plain CRS84 POINT geometry as its 2D
# map anchor (lon/lat), listed first.
#
# Block A: 12 m × 20 m footprint, 9 m tall (a small apartment block).
# Block B: 10 m × 15 m footprint, 6 m tall (a workshop).

@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix geo:     <http://www.opengis.net/ont/geosparql#> .
@prefix bot:     <https://w3id.org/bot#> .
@prefix v3:      <https://opentriplestore.org/demo/viewer-3d-demo/volumes#> .

# Zone grouping the two extruded blocks (a "zone" of volumetric demo buildings).
v3:ExtrudedBlocksZone a bot:Zone ;
    rdfs:label "Extruded building blocks (WKT-Z demo)"@en ;
    rdfs:comment "Two simple closed POLYHEDRALSURFACE Z solids near the Schependomlaan site, for the native-volumetric 3D path."@en ;
    bot:containsElement v3:BlockA , v3:BlockB .

# ── Block A — 12 m × 20 m × 9 m apartment block ──
v3:BlockA a bot:Element ;
    rdfs:label "Apartment block A (extruded solid)"@en ;
    dcterms:description "12 m × 20 m footprint extruded to 9 m — a closed polyhedral solid." ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83330 51.84090)"^^geo:wktLiteral ] ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "<http://www.opengis.net/def/crs/EPSG/0/7415> POLYHEDRALSURFACE Z (((185660 428040 0,185660 428060 0,185672 428060 0,185672 428040 0,185660 428040 0)),((185660 428040 9,185672 428040 9,185672 428060 9,185660 428060 9,185660 428040 9)),((185660 428040 0,185660 428040 9,185660 428060 9,185660 428060 0,185660 428040 0)),((185672 428040 0,185672 428060 0,185672 428060 9,185672 428040 9,185672 428040 0)),((185660 428040 0,185672 428040 0,185672 428040 9,185660 428040 9,185660 428040 0)),((185660 428060 0,185660 428060 9,185672 428060 9,185672 428060 0,185660 428060 0)))"^^geo:wktLiteral ] .

# ── Block B — 10 m × 15 m × 6 m workshop ──
v3:BlockB a bot:Element ;
    rdfs:label "Workshop B (extruded solid)"@en ;
    dcterms:description "10 m × 15 m footprint extruded to 6 m — a closed polyhedral solid." ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "POINT(5.83400 51.84090)"^^geo:wktLiteral ] ;
    geo:hasGeometry [ a geo:Geometry ;
        geo:asWKT "<http://www.opengis.net/def/crs/EPSG/0/7415> POLYHEDRALSURFACE Z (((185700 428040 0,185700 428055 0,185710 428055 0,185710 428040 0,185700 428040 0)),((185700 428040 6,185710 428040 6,185710 428055 6,185700 428055 6,185700 428040 6)),((185700 428040 0,185700 428040 6,185700 428055 6,185700 428055 0,185700 428040 0)),((185710 428040 0,185710 428055 0,185710 428055 6,185710 428040 6,185710 428040 0)),((185700 428040 0,185710 428040 0,185710 428040 6,185700 428040 6,185700 428040 0)),((185700 428055 0,185700 428055 6,185710 428055 6,185710 428055 0,185700 428055 0)))"^^geo:wktLiteral ] .
