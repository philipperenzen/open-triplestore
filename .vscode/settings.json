{
    // Give rust-analyzer its own target directory so its background `cargo check`
    // doesn't contend on the build lock with `cargo run` / `make watch` — the IDE
    // and your dev server stop blocking each other, so both feel much faster.
    // (target/rust-analyzer is under the already-gitignored target/.)
    "rust-analyzer.cargo.targetDir": true,
    "workbench.colorCustomizations": {
        "editor.lineHighlightBackground": "#06c1ff24",
        "editor.selectionBackground": "#fb00ff52",
        "editor.selectionHighlightBackground": "#00ff2621",
        "editor.wordHighlightBackground": "#1900ff40",
        "editorCursor.foreground": "#ffffffe3",
        "activityBar.background": "#594905",
        "titleBar.activeBackground": "#7D6607",
        "titleBar.activeForeground": "#FEFBEC",
        "titleBar.inactiveBackground": "#594905",
        "titleBar.inactiveForeground": "#FEFBEC",
        "statusBar.background": "#594905",
        "statusBar.foreground": "#FEFBEC",
        "statusBar.debuggingBackground": "#594905",
        "statusBar.debuggingForeground": "#FEFBEC",
        "statusBar.noFolderBackground": "#594905",
        "statusBar.noFolderForeground": "#FEFBEC"
    }
}