# ❌ §4.1 — four/five Core violations against da:Vaarwegbrug shape.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix da:  <https://data.example.nl/def/> .
@prefix wb:  <https://data.example.nl/id/waalbrug/> .
wb:FoutBrug a da:Vaarwegbrug ;
    da:bouwjaar "1936"^^xsd:integer ;     # wrong datatype (not gYear)
    da:aantalOverspanningen 0 ;           # < minInclusive 1
    da:beweegbaar "ja" .                  # not a boolean
    # missing: geo:hasGeometry         -> minCount violation
    # missing: da:vrijeDoorvaarthoogte -> minCount violation
