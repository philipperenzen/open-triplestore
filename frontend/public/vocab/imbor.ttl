imbor-term:9cef3698-9dea-41bb-bc17-207ef769c5e9 a skos:Concept;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Provinciaal wegennet"@nl.

imbor-term:9d0a3447-65e7-4ca7-a846-94cb10707273 a skos:Concept;
  skos:broader imbor-term:2263d3cf-a6a5-42f4-b161-26e535c17332;
  skos:definition "Een vrijverval rioolleiding die naast één of meerdere vrijverval rioolleidingen ligt, de leidingen sluiten op dezelfde putten aan."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Parallelriool"@nl.

imbor-term:9d169d98-3dc3-4c29-95fe-6467901945eb a skos:Concept;
  skos:broader imbor-term:4d2fdcc7-38c5-46ce-8b60-1338ab3ae731;
  skos:definition "De taludsteilte van het bovenwatertalud van de glooiing."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "taludsteilte bovenwatertalud"@nl.

imbor-term:9d1d0309-b546-4627-af88-5c0c7c11602b a skos:Concept;
  skos:definition "Niet RVV1990-borden; parkeergelegenheid."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "BW205rw"@nl.

imbor-term:9d1e1875-07ef-49cb-ba22-acbb8ba20969 a skos:Concept;
  skos:definition "Fluorescerende versie van D01 in rotondeportaal D01_BB12r."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "D01f_BB12r"@nl.

imbor-term:9d1fd5a8-12fc-4d0d-a09b-a605aa624448 a skos:Concept;
  skos:broader imbor-term:28dd4e3b-dcf0-4ff5-be6d-97718b128048;
  skos:definition "Verplichting niet het hoofdvaarwater op te varen of over te steken, indien daardoor schepen op het hoofdvaarwater zouden worden genoodzaakt hun koers of snelheid te wijzigen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "B.9a"@nl.

imbor-term:9d2790db-43b6-475b-b18f-4d2d172d5c82 a skos:Concept;
  skos:definition "Voegovergang van speciaal ontwikkeld flexibel materiaal, in situ vervaardigd, dat tevens het wegoppervlak vormt. Het oppervlak van de voegovergang is in lijn met het wegoppervlak."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Flexibele voegovergang"@nl.

imbor-term:9d2b1950-295f-440a-9124-fa228aa16e1a a skos:Concept;
  skos:definition "Een (thematisch) ruimtenet met de karakteristieke vorm van het natuurlijke weefsel van een spin."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Spinnenweb"@nl.

imbor-term:9d32c37f-9f24-4a41-8c69-86d20a5a6695 a skos:Concept;
  skos:broader imbor-term:bd07385d-20e8-48ee-9ca6-a646d5bf5e58;
  skos:definition "Honden aan de lijn."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "L1053"@nl.

imbor-term:9d374df8-18ea-404f-a887-e160a2796edd a skos:Concept;
  skos:definition "Trekkershut."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "ST23"@nl.

imbor-term:9d3c8410-4df4-4a69-b86c-9b20c9ea46ce a skos:Concept;
  skos:broader imbor-term:8af22f8b-a209-4924-8416-6783ab005373;
  skos:definition "Functionele ruimte die een voorziening bevat om bepaalde effecten van omgevingsfactoren te verminderen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Reducering"@nl.

imbor-term:9d5c8e65-e4d3-47e5-ac49-ed25f07940af a skos:Concept;
  skos:broader imbor-term:3ffa9f91-9949-4d30-8b44-d6eaa84e6acc;
  skos:definition "Als het eindpunt ontbreekt bij het onderdeel (doorlaat, pomp, wand) wordt uitgegaan van externe lozing. Het transport verdwijnt uit het stelsel."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Eindpunt onderdeel"@nl.

imbor-term:9d6999cd-0957-44d4-bf41-970c277c41e7 a skos:Concept;
  skos:definition "Klasse voor de bedekking met de beoogde beplanting van het beplantingsvak in bovengrens voorzien door, maar exclusief, het zeventigste percentiel van het beplantingsvak."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Sluiting < 70%"@nl.

imbor-term:9d6d695e-a6a0-4f0b-92c3-d0455143c9c0 a skos:Concept;
  skos:definition "The SI unit for measuring the flux of light being produced by a light source or received by a surface. The intensity of a light source is measured in candelas. One lumen represents the total flux of light emitted, equal to the intensity in candelas multiplied by the solid angle in steradians into which the light is emitted."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:note "http://qudt.org/vocab/quantitykind/LuminousFlux"@nl;
  skos:prefLabel "Lumen"@nl.

imbor-term:9d749e53-ede8-48c0-b61a-3d8ab59fa858 a skos:Concept;
  skos:definition "Een legverband dat gelijk is aan het visgraatverband, maar dan 90 graden gedraaid. Het wordt vaak gebruikt bij drukke straten vanwege de zeer hoge belastbaarheid van de stenen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Keperverband"@nl.

imbor-term:9d74e596-2cfc-4087-9273-e53e9584640b a skos:Concept;
  skos:definition "Groot Rijnschip. Een groot rijnschip, ook wel rijnaak genoemd, is een binnenschip dat is ontworpen voor waterwegen die men sinds 1992 indeelt in CEMT-klasse V."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:note "Maximum waarden: lengte = 110 , Breedte = 11,4 , diepgang geladen = 3,5 , strijkhoogte leeg/geladen = 7,1/5,4 , laadvermogen (ton) = 2051-3300"@nl;
  skos:prefLabel "Va - M8"@nl.

imbor-term:9d7b2248-9bbe-4038-9982-d36449b81e17 a skos:Concept;
  skos:broader imbor-term:4a641b48-0850-43d0-bb99-29134f5741ac;
  skos:definition "Aanduiding van de locatie van de beschoeiing ten opzichte van het wateroppervlak."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "boven- of onderwater"@nl.

imbor-term:9d82d7d1-658d-4ed4-be4e-786705135ba8 a skos:Concept;
