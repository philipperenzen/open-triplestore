  skos:definition "Enumeratietype voor de klasse FysiekObject en het attribuut modelnaam."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:note "Deze enumeratie is een referentielijst die organisatieafhankelijk is en in het IMBOR model zijn hier ook geen suggestiewaarden voor beschikbaar."@nl;
  skos:prefLabel "FysiekObjectModelnaam"@nl.

imbor-term:ce60bae0-bf9d-4838-898c-368ad5281124 a skos:Concept;
  skos:broader imbor-term:51f8d55e-cf24-4e74-a82a-ac4dc4c0c2e1;
  skos:definition "Afvoerend oppervlak van gesloten verharding met een afstroomlengte naar het lozingspunt op het rioolstelsel die groter is dan 100 m. Bijvoorbeeld: platte daken van fabrieken of parkeerplaatsen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "gesloten verhard oppervlak vlak uitgestrekt"@nl.

imbor-term:ce66fb0e-42d3-46ec-aa4e-6c2f00b5d9ae a skos:Concept;
  skos:definition "Het lichtdoorlatende deel van het object heeft een vertroebeld, licht wit visueel uiterlijk."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Melk"@nl.

imbor-term:ce685551-31fe-4eb8-93bb-503c98a04ce1 a skos:Concept;
  skos:broader imbor-term:375d5e2d-1b2a-4585-a7ca-fbbcc689f93f;
  skos:definition "Losse soort halfverharding: het is een verzamelnaam voor alle soorten nevengesteenten die bij de winning van steenkool vrijkomen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Mijnstenen"@nl.

imbor-term:ce698490-5160-4050-83ff-3413670c6bc4 a skos:Concept;
  skos:definition "De primaire, geplande af te leggen weg te gebruiken door voertuigen voor agrarische doeleinden."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Route landbouwverkeer: hoofdroute"@nl.

imbor-term:ce6b0396-13dd-4146-a642-4264a7051871 a skos:Concept;
  skos:definition "De klasse met als ondergrens een spanning van nul Volt en als bovengrens een spanning van tien Volt."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "0-10V"@nl.

imbor-term:ce6eb4dc-11d4-4e19-8c19-6fd0a90231ab a skos:Concept;
  skos:broader imbor-term:452db333-b5d0-4d2d-bdda-30938c717637;
  skos:definition "Type gedetailleerd van halfverharding, samenhangend. Siltige deklaag."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Leemdek"@nl.

