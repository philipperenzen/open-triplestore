imbor-term:129ff500-d93c-4c5f-b153-727513bfa060 a skos:Concept;
  skos:broader imbor-term:e135097c-1c89-44fa-86da-bb3372d64d13;
  skos:definition "Materiaal met retroreflecterende eigenschappen en met een belijning die reflecteert bij droge en natte weersomstandigheden, en dus goed zichtbaar is in het donker. Uitgevoerd met een profiel."@nl;
  skos:inScheme imbor-term:term-schema;
