imbor-term:f5416543-5f99-481d-a683-37815c5f2627 a skos:Concept;
  skos:broader imbor-term:928508de-47e4-417b-b1c9-c8cffc847a9b;
  skos:definition "Een \"telecommunicatie gebouw\" is een gebouw dat is ontworpen of gebruikt voor telecommunicatie doeleinden. Dit kan variëren van een gebouw met faciliteiten voor mobiele telefonie (zoals een \"Telecomhotel\" voor het distribueren van 4G-signalen) tot een datacenter of een gebouw met een centrale rol in een netwerk van verbindingen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Telecommunicatie gebouw"@nl.

imbor-term:f546b7ce-321f-425d-b44d-5b5c09e49933 a skos:Concept;
  skos:definition "Straatnaambord met 2 tekstregels, ondertekst en met gebiedsindeling in wit vlak boven de straatnaam."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "N02-4-(xx)"@nl.

imbor-term:f54e91a4-0633-4ccf-9772-837e124fb337 a skos:Concept;
