  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Vergunning"@nl.

imbor-term:1fe24772-eca8-4855-9b05-62a4a5e6d399 a skos:Concept;
  skos:broader imbor-term:a0a92cfb-a970-4968-a130-12a4bd1bb852;
