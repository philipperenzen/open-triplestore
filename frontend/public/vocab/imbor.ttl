imbor-term:f87e9d4c-5f02-4c82-9c89-58de1a748d54 a skos:Concept;
  skos:definition "Een glijbaan waarbij de glijbak de vorm heeft van een niet krommende, dalende helling, al dan niet met een uitloopsegment als verlenging."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Glijbaan type 1"@nl.

imbor-term:f8ada518-1c95-40c5-be33-f603e49a6dd4 a skos:Concept;
  skos:broader imbor-term:4a641b48-0850-43d0-bb99-29134f5741ac;
  skos:definition "Gekozen snelheid die maatgevend is voor de vormgeving van de weg en de ontwerpelementen, zodat bestuurders van voertuigen, indien niet gehinderd door het overige verkeer, bij die snelheid veilig en comfortabel kunnen rijden. NB: als uitgangspunt geldt de hoogste snelheid waarmee een enkel voertuig veilig en comfortabel over het betrokken weggedeelte kan rijden, indien de stroefheid van het wegdek, het zicht en de weersomstandigheden geen nadelige invloed uitoefenen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "ontwerpsnelheidsklasse"@nl.

imbor-term:f8aec143-e5a4-4002-bb65-a284f4e5ae44 a skos:Concept;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Schubzegge"@nl.

imbor-term:f8b20510-f0e3-4548-8058-ba8f7b75d934 a skos:Concept;
  skos:definition "Vaste waarde van 4,5 meter."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "4,5 m."@nl.

imbor-term:f8b20b25-0753-48f2-80d7-929eb6c585e5 a skos:Concept;
  skos:broader imbor-term:d115bf9e-495e-4857-9516-2d0512563fd3;
  skos:definition "Het object wordt gebruikt om toegang te verlenen tot een bepaalde plek."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Toegang verschaffen"@nl.

imbor-term:f8ba702c-5a31-429e-be79-66ce96b3bccd a skos:Concept;
  skos:definition "Het enumeratietype voor de domeinwaardenlijst van de klasse Ruimte en het attribuut verschijningsvorm."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "RuimteVerschijningsvorm"@nl.

imbor-term:f8bcd8bb-b2a5-4ba2-b891-3e2443bf7813 a skos:Concept;
  skos:definition "Volledig stofdicht en bescherming tegen opspattend water (<60° hoek)."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "IP63"@nl.

imbor-term:f8beb31a-64d8-4a16-8359-0e7ae2a7a421 a skos:Concept;
  skos:definition "Als de vorm van het object niet rechthoekig of rond is."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Anders (vorm)"@nl.

imbor-term:f8c14d43-1b46-4723-b153-80e3999a99cf a skos:Concept;
  skos:definition "Bescherming tegen objecten > 12mm en volledige waterdichtheid, zelfs bij onderdompeling (<1m)."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "IP27"@nl.

imbor-term:f8c1580f-82d7-4b77-a029-0c93a1b7b390 a skos:Concept;
  skos:definition "Om het object te bereiken moet men lopend door ondiep oppervlaktewater gebruikmakend van een waterdicht pak'."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Waadpak gebruiken"@nl.

imbor-term:f8c35441-7883-4ea0-934b-a55fa7d65451 a skos:Concept;
  skos:broader imbor-term:01c31fc9-202b-4037-8e95-4ef7e6d0860d;
  skos:definition "Een kenmerk voor de massa van het beheerobject."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "gewicht"@nl.

imbor-term:f8c9faf7-ba95-4d70-a1b9-9586ca55d0f1 a skos:Concept;
  skos:altLabel "Minigemaal"@nl;
  skos:broader imbor-term:100c3a15-3342-46fd-9f48-843c076571e9;
  skos:definition "Een rioolput met een inrichting bestemd voor het verpompen van afvalwater."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Pompput"@nl.

imbor-term:f8cb1c4d-ac0d-4a88-8a73-8519f2c392ab a skos:Concept;
  skos:broader imbor-term:59c1db07-edee-45db-92c7-0e0d32f7582b;
  skos:definition "Zonebord dat het begin van een zone waarin de maximumsnelheid dertig kilometer per uur is en het begin van een zone waar parkeren niet toegestaan is, aanduidt."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "A0130E01zb"@nl.

imbor-term:f8cd480f-a16e-4072-9c6c-d4495b5e9e57 a skos:Concept;
  skos:definition "De belastingklasse 30 volgens het Voorschrift voor het Ontwerpen en Vervaardigen van Stalen Bruggen van 1963, equivalent aan een gewicht van 200 kilogram per vierkante meter."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "VOSB 1963 Klasse 30"@nl.

imbor-term:f8dc46a2-26ff-4865-b4b9-861035466bfb a skos:Concept;
  skos:broader imbor-term:d115bf9e-495e-4857-9516-2d0512563fd3;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Fixeren putdeksel"@nl.

imbor-term:f8ddcda7-74c5-42c8-8a73-31dcadcae969 a skos:Concept;
  skos:definition "Bescherming tegen stofafzetting aan de binnenzijde en bescherming tegen krachtige waterstralen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "IP56"@nl.

imbor-term:f8e54e41-39ae-46cd-abc5-1d2cb125b3de a skos:Concept;
  skos:definition "Een profiellijn die de samenkomst van twee hellingsvlakken van verschillende materialen voorstelt aan de binnenkant van een dijk."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Kniklijn (binnen)"@nl.

imbor-term:f8e76bdc-9f99-4d95-a881-54cb4c96a807 a skos:Concept;
  skos:definition "Aanduiding van het einde van een zone waar betaald parkeren op basis van pinnen van toepassing is."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "BW112ze"@nl.

imbor-term:f8f06046-082b-4660-8019-7e34fef8132b a skos:Concept;
  skos:broader imbor-term:8ea13a09-8ec0-48b3-84bd-da0c1da1239c;
  skos:definition "Een speelterrein, vaak van diverse aard, dat toebehoort aan een (basis)school en intensief gebruikt wordt door de leerlingen van die school."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Schoolspeelplaats"@nl.

imbor-term:f8f838db-a603-46a6-a151-9f9b939bbd96 a skos:Concept;
  skos:definition "E-serie: scheepvaartborden Conform BPR / Aanwijzingstekens."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Aanwijzingsteken"@nl.

imbor-term:f8f8edd3-1eb6-4218-94bc-d3ebfe615036 a skos:Concept;
  skos:definition "Het enumeratietype voor de domeinwaardenlijst van de klasse Boom en het attribuut beoogde omloop boom regulier groeiend."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "BoomBeoogdeOmloopBoom(regulier)"@nl.

imbor-term:f9038b27-4b83-4065-aa7d-5abe77eaeb64 a skos:Concept;
  skos:definition "Een sociaal spel in de vorm van een slag-, toets- en snaarinstrument met een horizontaal gepositioneerde reeks grote witte en kleine zwarte toetsen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Piano"@nl.

imbor-term:f903cd48-efaa-460f-af77-cfc011d9dc7a a skos:Concept;
  skos:broader imbor-term:0e89b372-eb2e-4578-bf73-44c697e4abd1;
  skos:definition "Ruigte van Haagwinde (Haagwinde bedekt >50%)."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "RH"@nl.

imbor-term:f9051bfc-e321-4a27-8520-c162dd8655e1 a skos:Concept;
  skos:broader imbor-term:8af22f8b-a209-4924-8416-6783ab005373;
  skos:definition "Het gebied tussen sluizen, stuwen of gemalen in waar het water op dezelfde hoogte gehouden wordt en waarvoor één peilbesluit geldt."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Peilvak"@nl.

imbor-term:f90daa02-ed79-4202-9945-52e9ef079769 a skos:Concept;
  skos:broader imbor-term:bd07385d-20e8-48ee-9ca6-a646d5bf5e58;
  skos:definition "Tramhalte."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "L03c"@nl.

imbor-term:f915ca67-f5eb-4814-a2d0-21f0db99d1eb a skos:Concept;
  skos:definition "Het enumeratietype voor de domeinwaardenlijst van de klasse Kabeldraagsysteem en het attribuut verschijningsvorm."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "KabeldraagsysteemVerschijningsvorm"@nl.

imbor-term:f916823d-c287-44f2-a1d3-5882be0bd56e a skos:Concept;
  skos:definition "Aanduiding dat een camping zich in de richting van de links wijzende pijl bevindt."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "BW101lSk02"@nl.

imbor-term:f917df85-1b74-4170-b8cb-39b431146cd6 a skos:Concept;
  skos:broader imbor-term:4d43925f-e973-4313-9edd-80b90bbc411e;
  skos:definition "Een verhoogde rand van 3 tot 10 cm zorgt er dan voor dat het water niet over de brugrand stroomt, maar in de lengterichting van het brugdek (CROW-fietsbruggen)."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:note "Langs de rijbaan aangebrachte constructie van geringe hoogte om te voorkomen dat het verkeer van de weg raakt (RWS OTL). Betonnen rand ter geleiding van het verkeer; Bovenliggend: Aanrijbescherming: voorziening die een kunstwerk of wegmeubilair moet beschermen tegen beschadiging door aanrijdingen. Functie kan geleiding zijn."@nl;
  skos:prefLabel "Schampkant"@nl.

imbor-term:f926561e-5d34-47a8-b1b0-34c43ea1cb63 a skos:Concept;
  skos:definition "Een precisiesport waarbij het de bedoeling is dat de spelers afgeplatte ballen, bowls, zo dicht mogelijk naar een kleinere doelbal laten rollen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Bowls"@nl.

imbor-term:f926f92b-b314-4449-bb31-5a7d8384dd19 a skos:Concept;
  skos:definition "Rechts links."@nl;
  skos:inScheme imbor-term:term-schema;
