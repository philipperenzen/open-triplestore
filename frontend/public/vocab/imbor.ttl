  skos:definition "Einde lege pijlconfiguratie."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "T201e"@nl.

imbor-term:1f056ae7-cf33-44b2-8434-2d7ac4ba0ba7 a skos:Concept;
  skos:definition "Door wegmarkering in dwarsrichting aangegeven deel van de rijbaan ten behoeve van het oversteken."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Voetgangersoversteekplaats"@nl.

imbor-term:1f079405-d741-4399-a714-a527935dbad2 a skos:Concept;
