  skos:definition "Een legering die bestaat uit ijzer en een geringe hoeveelheid koolstof, zodanig dat dit metaal gekarakteriseerd wordt door de eigenschap van vervormbaarheid bij verhitting."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Staal"@nl.

imbor-term:4fcb8296-dafb-4c34-bc26-11eebaf4b737 a skos:Concept;
  skos:definition "Parkeerterrein."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "SP04"@nl.

imbor-term:4fdc633d-2cbe-4828-993a-07a0573391b3 a skos:Concept;
  skos:broader imbor-term:048614f6-fe5c-413c-862b-ae444dd3e652;
  skos:definition "Onderbord - C."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "OB901-C"@nl.

imbor-term:4fdd21b2-13ff-4361-9cb0-bc2f537ccc0f a skos:Concept;
  skos:definition "Bord dat het begin van een zone aanduidt waar een algemene plaatselijke verordening geldt."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "APV-zone"@nl.

imbor-term:4fea0e03-e9ae-4fbb-b6f3-d730ea6ca998 a skos:Concept;
  skos:definition "Aaneengesloten verharding waarbij de porositeit van de afzonderlijke elementen een poreus oppervlak realiseert."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Waterdoorlatende verharding"@nl.

imbor-term:4ff16979-c163-4ed1-9904-a3ac54972590 a skos:Concept;
  skos:altLabel "Bloemenblok"@nl;
  skos:broader imbor-term:54c784e0-420b-48ac-8798-18eb7fc9a861;
  skos:definition "Gebruiksfunctie van een vlak in een akkerperceel. Doel is biodiversiteit in de moderne agrarische bedrijfsvoering. Een bloemenblok bestaat uit een mengsel van streekeigen kruiden en planten van extensieve gewassen. Na het inzaaien wordt het in fases beheerd door opnieuw in te zaaien. Dit betreft een cyclus van 3 jaar. Een bloemenblok is een perfecte broedbiotoop voor akkervogels als Patrijs. In najaar en winter is er veel voedsel voor andere vogels. Er is een brede bloeiboog waardoor het een aantrekkelijke biotoop is voor insecten."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Bloemblok"@nl.

imbor-term:4fffc2ec-1aa6-42b7-aa48-77375f82a469 a skos:Concept;
  skos:broader imbor-term:21574552-bcd2-414d-820a-c8d6a3973859;
  skos:definition "Kunstmatige lichtbron, vaak tevens voorzien van een geluidsinstallatie, bij een kruispunt voor het waarschuwen van overig verkeer voor een naderende tram of voor het waarschuwen bij andere mogelijke onveilige situaties."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Waarschuwingslicht"@nl.

imbor-term:50035f2c-6ee1-4325-8c2f-6d9685e896a8 a skos:Concept;
  skos:broader imbor-term:c7a21e5b-8881-4a8d-b9f6-8e065feb4e3c;
  skos:definition "Einde lege pijlconfiguratie pijl rechtdoor."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "T201be"@nl.

imbor-term:500ab69f-2719-408f-907e-fdc5f2625801 a skos:Concept;
  skos:definition "Elliptische metaalhalidelamp met een enkele dubbele buis en een enkel eindstuk. De code is ontleend aan het LBS Lampcodesysteem van Zentralverband Elektrotechnik und Elecktronikindustrie. De equivalente ILCOS-code is: ME."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "HIE-S"@nl.

imbor-term:50125e92-b903-48d5-bc9d-80518a889aa3 a skos:Concept;
  skos:definition "Bij kruispunten op korte afstand van elkaar, in een strook voor een afslaande beweging als deze afslaande beweging op het eerste kruispunt niet is toegestaan."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Pijl rechts met hamerkopsymbool"@nl.

imbor-term:501cbda2-cfa8-433a-8d47-f4ab7231f7b4 a skos:Concept;
