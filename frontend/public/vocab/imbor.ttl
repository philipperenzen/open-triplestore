  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Flat Bank"@nl.

imbor-term:1f5beb68-e52a-41c1-b0b3-f3c06cdc564f a skos:Concept;
  skos:broader imbor-term:62a9a72a-f011-464a-a75d-62483a936b1e;
  skos:definition "Factor die afhankelijk is van het afvoerend oppervlak en waarmee de hoeveelheid regenwater per tijdseenheid moet worden vermenigvuldigd om de verwachte instroom naar het systeem van aansluitleidingen of de buitenriolering af te schatten."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "afvoercoëfficiënt"@nl.

imbor-term:1f619e1c-68fd-4aae-b097-92c576c9d9d1 a skos:Concept;
  skos:definition "Type van een communicatieprotocol."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "i/o"@nl.

imbor-term:1f62d07a-9430-46d2-9b6c-752d2f42057f a skos:Concept;
  skos:definition "Anagallis arvensis s. foemina, een teer kruid dat liggende stengels heeft met kleine tegenoverstaande bladeren en opvallend helder blauwe bloemen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Blauw guichelheil"@nl.

imbor-term:1f6f1a2d-ec3c-43d7-b7cc-1cf7cdce8b45 a skos:Concept;
  skos:definition "Wegmarkering in de vorm van een pijl met naar links krommende kop die weggebruikers aangeeft dat deze rijstrook links van de doorgaande rijstroken afsplitst."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Pijl gebogen links"@nl.

imbor-term:1f762ce1-3b56-4f12-8e38-3ce58b24f83b a skos:Concept;
  skos:definition "Equivalent van 70NE3 in NEN-EN 12767: 2019. De botsklassecode is opgebouwd uit een combinatie van impactsnelheid (70 km/h), energieabsorptiecategorie (NE), het veiligheidsniveau voor de inzittende(n) (C), de specificatie dat collapsmodus niet is opgenomen (NR), dat het object gevoelig is voor botsingen vanuit meerdere richtingen (MD) en er geen sprake is van indeuking van het dak (0)."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "70-NE-B-S-NR-MD-0"@nl.

imbor-term:1f880ec5-459a-4279-ae8b-aa5ad2e2685a a skos:Concept;
  skos:altLabel "Kavelscheiding, terreinafscheiding, perceelscheiding"@nl;
  skos:broader imbor-term:d115bf9e-495e-4857-9516-2d0512563fd3;
