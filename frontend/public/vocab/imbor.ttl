imbor-term:c5a1be73-f0fc-4663-b409-bc223ab0ad78 a skos:Concept;
  skos:definition "The hour (common symbol: h or hr) is a unit of measurement of time. In modern usage, an hour comprises 60 minutes, or 3,600 seconds. It is approximately 1/24 of a mean solar day. An hour in the Universal Coordinated Time (UTC) time standard can include a negative or positive leap second, and may therefore have a duration of 3,599 or 3,601 seconds for adjustment purposes. Although it is not a standard defined by the International System of Units, the hour is a unit accepted for use with SI, represented by the symbol h."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:note "http://qudt.org/vocab/quantitykind/Time"@nl;
  skos:prefLabel "Uur"@nl.

imbor-term:c5ad67e8-b01b-4e4f-84e2-ec8f85d32686 a skos:Concept;
