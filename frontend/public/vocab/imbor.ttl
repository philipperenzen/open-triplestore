imbor-term:599d4f8a-3f2f-4953-ba2b-99f31618fcdb a skos:Concept;
  skos:broader imbor-term:54c784e0-420b-48ac-8798-18eb7fc9a861;
  skos:definition "Een plasberm is een natte oeverstrook die langs een waterloop wordt aangelegd. Een plasberm wordt aangelegd om planten te laten groeien, en daardoor tot een wallekant te komen met meer biodiversiteit. De hoogte is gelijk aan het heersende peil van de watergang. Hierdoor is hij het gehele jaar nat."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Plasberm"@nl.

imbor-term:59a2df75-685e-460e-8758-f19e917098ed a skos:Concept;
