  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Enkelvoudige taludkabelbaan voor zittend gebruik"@nl.

imbor-term:122d78d4-fc00-4cc8-84c4-136372e93f44 a skos:Concept;
  skos:broader imbor-term:2fa08fa1-cd04-4101-9dc2-9164e6d7e288;
  skos:definition "Plantenbak, ingeplant met botanische rozen. Botanische rozen zijn wilde, niet gekruiste of geënte rozensoorten."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Botanische rozen in plantenbak"@nl.

imbor-term:12365f4a-4a02-4be7-ad80-3e3dfca68b7e a skos:Concept;
  skos:definition "Subtropisch zwembad."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "SS23"@nl.

imbor-term:124ff4c4-7d1a-4c42-8464-62595ee11c73 a skos:Concept;
  skos:altLabel "Schrikhek"@nl;
  skos:broader imbor-term:2fb61a80-f0da-4365-8c28-4e42d67dac76;
  skos:definition "Constructie in de vorm van een hek, voorzien van rode en witte blokken of chevrons, die het verkeer attendeert op een gevarenpunt."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Waarschuwingshek"@nl.

imbor-term:125947ae-abbf-4d0e-b925-70d4143f411c a skos:Concept;
  skos:definition "Scouting."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "SS06"@nl.

imbor-term:125ab3bd-c944-4eb8-b918-a6cf7d5da256 a skos:Concept;
  skos:definition "Gesloten verharding bestaande uit asfaltbeton of andere met bitumen gebonden materialen die niet aan het oppervlak gelegen is, maar juist een van de intermediaire lagen van de constructielagen vormt."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Asfaltverharding (tussenlaag)"@nl.

imbor-term:1273a25a-3828-45e1-9272-bc2728d324da a skos:Concept;
  skos:definition "Een ondergronds laadpunt onder een laadvak dat een magnetisch veld opwekt tussen een spoel die onderdeel is van het laadpunt en een spoel die onderdeel uitmaakt van een elektrisch voertuig voor de overdracht van elektrische stroom."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Inductielaadpunt"@nl.

