  skos:broader imbor-term:f2cc5e34-3a37-4687-9c95-04ebc2632dc1;
  skos:definition "Een constructie ten behoeve van het verplaatsen van afvalwater."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:note "Voor het waterschap zijn in principe alleen de riooleindgemalen interessant, waar overdracht van afvalwater plaatsvindt naar een stelsel dat onder beheer van dit waterschap is."@nl;
  skos:prefLabel "Rioolgemaal"@nl.

imbor-term:1e689c4f-7778-47ea-b3ee-382468f7325d a skos:Concept;
  skos:broader imbor-term:29bbd3d3-f412-41d8-98fe-0190b60dead2;
  skos:definition "Een houtsingel, boomsingel of kortweg singel (in Nederland) of een houtkant (in Vlaanderen) is een brede strook met bomen en struiken als afscheiding tussen weilanden en akkers en ook wel langs beken en waterlopen. Een houtsingel is een lijnvormig landschapselement van 4 tot 20 meter breed en minimum 25 meter lang. Houtsingels lijken veel op houtwallen. Bij een houtwal is er sprake van een opgeworpen wal, waar de beplanting op staat."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Houtsingel"@nl.

imbor-term:1e70cca6-70a5-4d6f-99ef-695c7603b0ef a skos:Concept;
  skos:definition "Eenmaal om een periode van tweeënzeventig kalendermaanden."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "1 x per 6 jaar"@nl.

imbor-term:1e743e09-9ab3-471a-9a44-154ec4908e69 a skos:Concept;
  skos:broader imbor-term:b2ba21e5-faf0-4339-9614-55f712723bc3;
  skos:definition "Hout dat afkomstig is van loofbomen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Hardhout"@nl.

imbor-term:1e7d9c3d-2b80-487b-a302-ff34a6d70f4c a skos:Concept;
  skos:definition "Ranunculus polyanthemos subsp. polyanthemoides, een vaste plant uit de ranonkelfamilie. De plant wordt 30-90 cm hoog en heeft tamelijk smalle bladslippen. Staat op de Rode Lijst."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Kalkboterbloem"@nl.

imbor-term:1e8f7b3f-3e14-4fc6-b7de-81d039660509 a skos:Concept;
  skos:broader imbor-term:ea81a6ea-25ef-4d79-bdc0-9b995dd7fc18;
  skos:definition "Einde verbod voor vrachtauto’s om motorvoertuigen in te halen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "F04"@nl.

imbor-term:1e9a3cdd-3b5c-4198-91fe-56a1cfb702ec a skos:Concept;
  skos:definition "Wegknoop met 1 verbinding en betreft een doorgaande verbinding met het wegennetwerk van een buurland."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Grensknoop"@nl.

imbor-term:1eaa0b0c-b83c-45f3-b277-6bd3b36fe761 a skos:Concept;
  skos:broader imbor-term:943bbe5d-3483-43ae-abe3-7b52b054343b;
  skos:definition "Een persluchtleiding is een systeem van leidingen en hulpstukken die bedoeld is om perslucht van een compressor naar verbruikspunten te transporteren. Deze leidingen zijn essentieel voor het leveren van perslucht aan pneumatische gereedschappen en systemen in diverse toepassingen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Persluchtleiding"@nl.

imbor-term:1eb550a3-d248-4684-854c-46b48e76cb26 a skos:Concept;
  skos:altLabel "Draineerbuis, Drainagebuis, Exfiltratieleiding  "@nl;
  skos:broader imbor-term:b09b6aa8-cd2c-4984-827e-060e7db59a36;
  skos:definition "Een leiding met doorlatende wanden bestemd voor het op peil houden van het grondwater. Kan ook beschouwd worden als een soort voorziening om water te onttrekken."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Drain"@nl.

imbor-term:1ed269af-7f93-4832-83dc-1896441b300a a skos:Concept;
  skos:definition "Een overdekt speeltoestel dat lijkt op een huisje waar men in kan spelen en als onderdeel een balkon heeft."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Speelhuis met balkon"@nl.

imbor-term:1ed6b064-f1b1-4ced-b20e-6201288ba44e a skos:Concept;
  skos:definition "De afgemeten, ruimtelijk strekkende hoeveelheid van veertig duizendsten van een meter."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "40 mm."@nl.

imbor-term:1ee97fdb-36ff-46b1-ad09-867eea70c019 a skos:Concept;
  skos:definition "Invaliden visplaats."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "SG05"@nl.

imbor-term:1efd6d95-90bd-443a-a12d-e3e04a8a01a5 a skos:Concept;
