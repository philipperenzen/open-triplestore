  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Scheiden van percelen"@nl.

imbor-term:1f8d47ea-0909-41db-8661-27335e40748e a skos:Concept;
  skos:definition "Een oppervlaktebehandelingsproces om een dunne egale deklaag op een oppervlakte aan te brengen middels een roterende beweging."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Spincoating"@nl.

imbor-term:1f8d6c4e-5bc1-4595-b1a5-9658bd650afc a skos:Concept;
  skos:broader imbor-term:7f664acc-7dca-4b10-bc06-2f069e205498;
  skos:definition "Een explosievrije of explosieveilige kolk kan worden uitgevoerd als straatkolk voor in het wegdek bij bijvoorbeeld tankstations. Het rooster komt gelijk te liggen met het wegdek en kan worden geopend om de kolk leeg te zuigen of om het leidingwerk of kolk te controleren."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Explosievrije kolk"@nl.

imbor-term:1f942fa7-f753-46ee-af28-4c3fe55e2f3b a skos:Concept;
  skos:definition "Het object heeft de vorm van meetkundig object dat vijf hoeken heeft."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Vijfhoekig"@nl.

imbor-term:1fa4a97c-10d6-4444-b50f-e48e02e43c66 a skos:Concept;
  skos:definition "Het enumeratietype voor de domeinwaardenlijst van de klasse Constructie en het attribuut stromingsrichting."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "ConstructieonderdeelStromingsrichting"@nl.

imbor-term:1fab6e7f-0de4-4972-9f2a-f18edeebd4c1 a skos:Concept;
