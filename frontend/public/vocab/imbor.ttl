  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Naderingslicht"@nl.

imbor-term:59c1db07-edee-45db-92c7-0e0d32f7582b a skos:Concept;
  skos:definition "Categorie A: bevat alle officiële verkeersborden RVV1990. De A-serie verkeersborden zijn snelheid gerelateerd, het verkeersbord geeft de maximum (rode borden) of adviessnelheid (blauwe borden) weer."@nl;
  skos:inScheme imbor-term:term-schema;
