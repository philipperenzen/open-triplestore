  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "J04"@nl.

imbor-term:1fe3af4f-49ae-405b-9313-1bfaae6847f5 a skos:Concept;
  skos:definition "Boompunt onjuist, maar niet op kaart gecorrigeerd."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Onjuist, niet gecorrigeerd"@nl.

imbor-term:1fe49100-f9f5-470a-9e29-bea6f82cbee0 a skos:Concept;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Grasplaat"@nl.

imbor-term:1ff150d3-087b-460b-8f63-2b54cb4ebd5a a skos:Concept;
