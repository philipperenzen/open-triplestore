imbor-term:5a622813-bc85-4954-b516-aeb7fe1d3ced a skos:Concept;
  skos:broader imbor-term:bd07385d-20e8-48ee-9ca6-a646d5bf5e58;
  skos:definition "Grensbord met Nederland na 1 kilometer."@nl;
  skos:inScheme imbor-term:term-schema;
