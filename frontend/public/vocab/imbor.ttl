  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Geo-objectWegcategorieDuurzaamVeiligGedetailleerd"@nl.

imbor-term:1f50a082-b429-481c-85f9-f525357b2a38 a skos:Concept;
  skos:definition "Speelelement dat als toegang/uitgang kan dienen met een hellingshoek van meer dan 45° ten opzichte van het horizontale vlak."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:note "Is een constructie-onderdeel van Speeltoestel"@nl;
  skos:prefLabel "Steil speelelement"@nl.

imbor-term:1f597a2b-7b27-4473-bdae-8f4f58a99d4c a skos:Concept;
