imbor-term:75cb378b-562f-4a65-9205-251a2cbbe879 a skos:Concept;
  skos:definition "De domeinwaarde van een attribuut is niet vastgesteld."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Niet bepaald"@nl.

imbor-term:75cd1296-b121-406f-a1b3-c9f13f44e032 a skos:Concept;
  skos:broader imbor-term:4a641b48-0850-43d0-bb99-29134f5741ac;
  skos:definition "Aanduiding ondersteunende voorzieningen, boomgerelateerd."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "boomvoorziening"@nl.

imbor-term:75dbc715-fba9-496b-a43f-ed4a787dad2a a skos:Concept;
  skos:broader imbor-term:27513d25-8e38-453c-a51c-8d15cce619a5;
  skos:definition "Richting van het bord ten opzichte van het noorden in graden met een nauwkeurigheid van 5 graden. De oriëntatierichting wordt met de klok mee van 0 tot 360 graden vastgelegd."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "oriëntatierichting"@nl.

imbor-term:75f20cde-799f-4d8a-bbe8-40f62a43d80a a skos:Concept;
  skos:definition "Overwinteringsgebieden voor amfibieën kunnen zijn: in gaten in de grond, onder bladhopen of andere dode plantenresten. Op het land, soms ook in het water."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Winterverblijf amfibieën"@nl.

imbor-term:75f653e0-7ba6-45ca-b34c-1fbd533ca5ea a skos:Concept;
  skos:broader imbor-term:37f4a011-09d4-4062-817b-26c55883331d;
  skos:definition "Planologische duiding beoogde omloop (jaren) eindbeeld, van een snelgroeiende boom."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "beoogde omloop boom (snelgroeiend)"@nl.

imbor-term:760460a0-e012-4de4-b671-70f348996019 a skos:Concept;
  skos:altLabel "Infiltratieveld, Regenwaterbuffer"@nl;
  skos:broader imbor-term:7912b057-b487-45ea-a0b0-e23e11754b62;
  skos:definition "Een wadi is een ondiepe, meestal begroeide verlaging in het landschap die regenwater opvangt en laat infiltreren in de bodem. Het is een term die oorspronkelijk uit het Arabisch komt, waar het \"dal\" of \"rivierbedding\" betekent, vaak droog, behalve tijdens regenbuien. In Nederland en België wordt een wadi gebruikt als waterbeheermaatregel om wateroverlast te verminderen en droogte tegen te gaan door regenwater te bufferen en te laten infiltreren."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Wadi"@nl.

imbor-term:760ec27f-ff07-4ed6-b298-741f9bd308d8 a skos:Concept;
  skos:altLabel "Infraroodcamera"@nl;
  skos:broader imbor-term:0d867912-2959-4774-a143-dbd38693440d;
  skos:definition "Een warmtebeeldcamera, ofwel warmte camera, is een meetinstrument waarmee infraroodstraling in beeld wordt omgezet."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Warmtecamera"@nl.

imbor-term:761670af-4ef3-4681-b2a6-4774fc565bf6 a skos:Concept;
  skos:broader imbor-term:32aaee25-0a7a-4eca-91eb-9b7fe4c3ce2f;
  skos:definition "Trapconstructie waardoor stroomopwaarts zwemmende vis zich stapsgewijs van het ene naar het andere waterniveau kan verplaatsen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Vistrap"@nl.

imbor-term:762924e3-29ff-4734-a47a-39a642becf55 a skos:Concept;
  skos:broader imbor-term:29bbd3d3-f412-41d8-98fe-0190b60dead2;
  skos:definition "Agrarisch grasland, ook wel open grasland genoemd, is een open landschap waar grasland het meest voorkomende vegetatie type is. Vaak is dit gebied doorkruist door sloten, weteringen en vaarten. Een deel van het grasland kan vochtig en kruidenrijk zijn."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Agrarisch grasland"@nl.

imbor-term:762cdf71-3316-427b-a5c0-9bbcfee1bfab a skos:Concept;
  skos:definition "Rijstrook linksaf doorgaand en rechtsaf afgesloten."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "L10-04r_C01t"@nl.

imbor-term:76311870-980b-4050-9de2-9e52f9199709 a skos:Concept;
  skos:definition "Martes martes, dit zoogdier heeft de grootte van een huiskat maar bezit veel kortere poten."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Boommarter"@nl.

imbor-term:76339ac6-5b4c-4526-ac41-c01a89611174 a skos:Concept;
  skos:definition "Een speeltoestel met een verende as bestaande uit meerdere veren die een enkele richting in bewegen, met meerdere zitplaatsen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Meerpersoons wipveer"@nl.

imbor-term:76385974-f8f0-48e2-9c62-8e3952897033 a skos:Concept;
  skos:broader imbor-term:a5072498-b06b-4ba5-bba3-6304aa7c4607;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Gestapelde woning"@nl.

imbor-term:763f006e-b51a-497f-8867-55c4bc486981 a skos:Concept;
  skos:broader imbor-term:8af8b8fa-5bbe-4d8f-b053-c0276fdaf7d2;
  skos:definition "Paal(tje) die de locatie en ligging aangeeft van een waterleiding."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Waterleidinglocatiepaal"@nl.

imbor-term:765cf3d6-b408-41b2-855d-c1133090fcf7 a skos:Concept;
  skos:definition "Gebouw dat onderdeel uitmaakt van een reeks aan elkaar verbonden gebouwen die als zodanig in één project zijn gerealiseerd."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Repeterend"@nl.

imbor-term:766ded87-ffc2-43a8-920c-0ee2dc0d05bd a skos:Concept;
  skos:broader imbor-term:23174663-8f19-451c-84d7-70f5d66ba7cc;
  skos:definition "Oever met."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "DOS"@nl.

imbor-term:76763f0f-0698-4684-96e7-a91de069eea4 a skos:Concept;
