  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "SS25"@nl.

imbor-term:f55501bb-fede-4208-9cf1-66d8a33ecfbe a skos:Concept;
  skos:definition "Uitwijkroute pijl rechtsaf slaan met routenummer."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "BW501rh"@nl.

imbor-term:f5566eb7-f3a7-46ad-b099-a2404974779f a skos:Concept;
  skos:definition "6 kabels die constructief op de kast aangesloten kunnen worden."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "6 richtingen"@nl.

imbor-term:f55dfd44-6ff0-463f-961d-ecc59b0fc2c5 a skos:Concept;
  skos:broader imbor-term:1d3ccbac-ff0c-4aa5-b3a6-e2d8446e02cd;
  skos:definition "Afkorting van steenmastiekasfalt, een asfaltsoort die binnenstedelijk veel gebruik ziet en bestaat uit in grote mate gebroken materiaal dat grotendeels is opgevuld met mastiek, een materiaal dat wordt vervaardigd uit bitumen, zand en een vulstof. Equivalent aan oude naamgeving 0/11 type 2."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "SMA-NL 11B"@nl.

imbor-term:f572be73-8caa-4cb9-b5ab-d30bf12f178a a skos:Concept;
