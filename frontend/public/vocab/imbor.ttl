  skos:prefLabel "L14_OB401"@nl.

imbor-term:efece16c-6b0a-401c-9e5d-1b65eb7d6dd5 a skos:Concept;
  skos:definition "Metre per second is an SI derived unit of both speed (scalar) and velocity (vector quantity which specifies both magnitude and a specific direction), defined by distance in metres divided by time in seconds. The official SI symbolic abbreviation is mu00b7s-1, or equivalently either m/s."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:note "http://qudt.org/vocab/quantitykind/LinearVelocity"@nl;
  skos:prefLabel "Meter per seconde"@nl.

imbor-term:eff11bff-7ec5-4ddf-a10a-f61d93674811 a skos:Concept;
  skos:definition "Het enumeratietype voor de domeinwaardenlijst van de klasse Verkeersbord en het attribuut verschijningsvorm."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "VerkeersbordVerschijningsvorm"@nl.

imbor-term:eff6f308-0cfa-467c-8021-f226792202e7 a skos:Concept;
  skos:definition "Het datatype vertegenwoordigt een tijdsduur uitgedrukt in een aantal jaren, maanden, dagen, uren, minuten en seconden. Het uitdrukkingsschema is PnYnMnDTnHnMnS, waar P de gefixeerde waarde waarmee de uitdrukking begint, nY is het aantal jaar gevolgd door de gefixeerde waarde Y, nM is het aantal maanden gevolgd door de gefixeerde waarde M, nD is het aantal dagen gevolg door de gefixeerde waarde D, T is een gefixeerde waarde die de datum en de tijd scheidt, nH is het aantal uren gevolgd door de gefixeerde waarde H, nM is het aantal minuten gevolgd door de gefixeerde waarde M, en nS is het aantal seconden gevolgd door de gefixeerde waarde S."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "xsd:duration"@nl.

imbor-term:efff79b2-e063-472c-b868-a4d1140ab321 a skos:Concept;
  skos:definition "Een oppervlaktebehandeling waarbij op metalen zoals aluminium een oxidelaag wordt aangebracht."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Geanodiseerd"@nl.

imbor-term:f00a7120-a8a0-48b4-8603-d5d62a3ecec6 a skos:Concept;
  skos:broader imbor-term:af1fff65-9a0a-46af-9fa6-304c7ed99304;
  skos:definition "Vaste (niet drijvende) waterbouwkundige constructie voor het aanleggen van schepen en bedoeld om deze schepen vanaf de wal te laden en te lossen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Steiger"@nl.

imbor-term:f00a89e5-c7bc-4e78-9f4f-082e95b92074 a skos:Concept;
  skos:definition "Wegmarkering in de vorm van een pijl met een drievoudige kop: één links wijzende kop die weggebruikers aangeeft dat bij deze rijstrook links afgeslagen kan worden, één rechte kop die aangeeft dat deze rijstrook verder gaat in doorgaande richting en één rechts wijzende kop die weggebruikers aangeeft dat bij deze rijstrook rechts afgeslagen kan worden."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Pijl links/rechtdoor/rechts"@nl.

imbor-term:f00e2d96-4e50-4dc2-8c6c-94bec612bcca a skos:Concept;
  skos:definition "Groen dat onderdeel is van de ecologische (hoofd)structuur zoals opgenomen in een ecologisch beleidsplan of vergelijkbaar plan: ontwikkeling flora en fauna, biodiversiteit, ecologische verbindingszones en passages, etc."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Onderdeel ecologische structuur"@nl.

imbor-term:f01c5419-820a-4fd0-8c8d-c23d24fbcb8d a skos:Concept;
