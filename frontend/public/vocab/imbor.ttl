  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Klaphek"@nl.

imbor-term:59ae307b-4b53-49b5-a957-7d9c8b906c41 a skos:Concept;
  skos:broader imbor-term:62d75ed1-7b9c-4835-8706-33b443ef2875;
