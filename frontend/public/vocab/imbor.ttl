imbor-term:1fb6a66d-49e9-46c6-864a-d7e9755e1002 a skos:Concept;
  skos:broader imbor-term:51f8d55e-cf24-4e74-a82a-ac4dc4c0c2e1;
  skos:definition "Het oppervlakte van het onderwatertalud van de glooiing."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "oppervlakte onderwatertalud"@nl.

imbor-term:1fcd196c-7419-4254-a150-75b21c524227 a skos:Concept;
  skos:broader imbor-term:2ac28d46-803e-45d4-8390-9d71e45858e1;
  skos:definition "Paal waaraan een vlag bevestigd kan worden."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Vlaggenmast"@nl.

imbor-term:1fcfc05e-e33e-4fd0-9d91-9358670e6940 a skos:Concept;
  skos:broader imbor-term:014f9bfd-3657-44ec-bf5c-8d7a8b7dcd4d;
  skos:definition "Strook grond langs een spoorweg."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Spoorberm"@nl.

imbor-term:1fd8f250-dcb1-4a1a-8eb4-d7ac810b5b52 a skos:Concept;
  skos:definition "Aaneengesloten verharding waarbij de porositeit van de afzonderlijke elementen een poreus oppervlak realiseert en waar er tevens ook in het verharde oppervlak voorzieningen aangebracht zijn om water sneller af te voeren."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Waterpasserende en -doorlatende verharding"@nl.

imbor-term:1fdb7f3b-ab55-4868-bc56-86854985fec8 a skos:Concept;
  skos:broader imbor-term:291e6f76-66af-4c3c-b37f-12c4f5675429;
