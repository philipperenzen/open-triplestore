imbor-term:e7234fa2-4147-409a-9986-0685f32bf925 a skos:Concept;
  skos:definition "Een combinatie uit tafel, bank en/of ramp, van twee zijden te berijden. Over het algemeen gebruikt men in Nederland: \"bank to bank\" , \"quarter to bank\", \"Quarter to Quarter\"."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Fly box"@nl.

imbor-term:e7251036-ec1e-451f-8414-b37db47d0832 a skos:Concept;
