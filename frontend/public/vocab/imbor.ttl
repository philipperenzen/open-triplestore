imbor-term:128bbdca-2b86-4a5b-ac40-7be0284293b9 a skos:Concept;
  skos:broader imbor-term:6325b757-caa9-4966-a1d8-72656e9dd350;
  skos:definition "De put die een scheidingselement is voor het rioleringsperceel van de gemeente en dat van de particulier."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Erfafscheidingsput"@nl.

imbor-term:1290313b-448f-4572-af61-98415540c841 a skos:Concept;
  skos:broader imbor-term:099c4c75-b063-4993-9dac-53155dfcf0d4;
  skos:definition "P+R staat voor 'Park and Ride'. Deze parkeerterreinen zijn bedoeld voor mensen die hun auto parkeren en verder reizen met het openbaar vervoer naar hun uiteindelijke plaats van bestemming."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "P+R terrein"@nl.

imbor-term:12925c55-b4f8-412e-8c0a-f79eb2f34643 a skos:Concept;
