  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Nationaal landschap"@nl.

imbor-term:e6dd6569-ae48-43f2-8653-df633d2e199d a skos:Concept;
  skos:definition "Elke achromatische waarde van lichtsterkte (de hoeveelheid licht uitgezonden door een lichtbron) die het menselijk oog kan waarnemen tussen wit en zwart."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Grijs"@nl.

imbor-term:e6f696bb-743e-4d3d-93a3-13a2bb644762 a skos:Concept;
  skos:altLabel "Matig zettingsgevoelig"@nl;
