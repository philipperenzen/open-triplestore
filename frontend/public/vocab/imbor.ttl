imbor-term:f6fea586-c0a7-4f8b-bcbf-003116122aaf a skos:Concept;
  skos:definition "Een oplastechniek waar door middel van een hoogvermogen laser een dunne laag van het basismateriaal wordt gesmolten. Het wordt toegepast om de oppervlakte-eigenschappen van metalen en machineonderdelen plaatselijk te verbeteren. Ook wel ‘laser oplassen’, ‘laser overlay welding’ of ‘laser metal deposition’ genoemd."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Lasercladden"@nl.

imbor-term:f70f8d65-34f0-4579-b049-19af3ba8c534 a skos:Concept;
