  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "SV06"@nl.

imbor-term:1ff46707-1609-4721-9e7a-af1fadc57161 a skos:Concept;
  skos:definition "Al of niet gemengde brede heesterbeplanting die aan de bovenkant en de zijkant(en) wordt geschoren, in de vorm van een blok. Verschil met de lijnvormige haag is de grotere breedte. Ook wel geschoren heestervak genoemd."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Blokhaag"@nl.

imbor-term:1ff4bf81-692e-4e82-9756-2d722bb29292 a skos:Concept;
  skos:broader imbor-term:e5e88d5a-b7bd-4874-b42b-46ea94998792;
  skos:definition "Vaste planten die door hun natuurlijke groeiwijze en plantafstand de bodem volledig bedekken. Hebben een horizontale groeiwijze, kruipen over de grond en/of maken ondergrondse uitlopers. Deze beplanting heeft een zodenvormend karakter."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Bodembedekkende vaste planten in plantenbak"@nl.

imbor-term:200f7c62-fcd9-4cf9-a9fc-dc1bf0622d28 a skos:Concept;
  skos:broader imbor-term:683d6c4e-a4f8-42be-9764-9f45462b5439;
  skos:definition "Een kleine watergeul, die ontstaat als gevolg van een dijkdoorbraak of is een restant van een ingedijkte vroegere getijdengeul."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Kreek"@nl.

imbor-term:2012b339-ddfe-4461-bcf5-982ebedab91c a skos:Concept;
  skos:broader imbor-term:1b989ac7-fda9-4808-b483-0067f12b617f;
  skos:definition "Afkorting voor 'International Mobile Subscriber Identity'; een uniek nummer dat bij digitale communicatie verzonden wordt om de drager van de zender te identificeren."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "imsi"@nl.

imbor-term:201e5e58-f5bb-444c-ba50-060380cafe7c a skos:Concept;
  skos:broader imbor-term:2ac28d46-803e-45d4-8390-9d71e45858e1;
  skos:definition "Installatie-element met als doel schepen te laden en lossen."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Laadbrug"@nl.

imbor-term:201e6df5-929e-4f83-aa71-cb439ec8a1f1 a skos:Concept;
  skos:broader imbor-term:4e8bc7e2-fe1a-4dbc-a5df-11cb40bdeccd;
  skos:definition "Let op: tegemoetkomend verkeer, rechtdoor gaande fietsers en voetgangers op zebrapad."@nl;
  skos:inScheme imbor-term:term-schema;
