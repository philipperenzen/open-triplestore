imbor-term:1114f557-5765-4871-8be7-ea240a17dbd0 a skos:Concept;
  skos:broader imbor-term:4a641b48-0850-43d0-bb99-29134f5741ac;
  skos:definition "Gemiddelde verkeersbelasting van de verharding."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:note "Conform concept-publicatie ´Onderbouwing en differentiatie onderhoudsniveaus weginfrastructuur´. De huidige tabel wegtypen uit publ. 146/147 (Wegtype bestaand) is in feite een combinatie tussen de 'wegcategorie' en de belasting. Deze tabel gaat waarschijnlijk verdwijnen. Vooruitlopend daarop is 'Wegtype bestaand' verwerkt in twee nieuwe tabellen, mede op basis van het CROW-project 'Differentiatie onderhoudsniveaus verhardingen', namelijk in 'wegtype nieuw' en 'belasting'. Op basis van de bestaande wegtype indeling is een indeling in 3 belastingklassen te maken: zwaar, normaal (gemiddeld), licht."@nl;
  skos:prefLabel "belasting"@nl.

imbor-term:112709b9-e0c5-4dd5-ac28-f06e788b1b96 a skos:Concept;
