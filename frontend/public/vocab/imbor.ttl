  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "As fietspad"@nl.

imbor-term:1f12c737-5071-47f4-8b3a-5701c9a8f997 a skos:Concept;
  skos:definition "Een apparaat dat bevestigd is aan een (span)draad."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Overspanningsbevestiging"@nl.

imbor-term:1f205b64-988a-4c7e-b3db-cde9cad3e933 a skos:Concept;
  skos:broader imbor-term:40701e9f-dffe-45a9-8232-9bf12668e8f1;
  skos:definition "Aanduiding voor de aanwezigheid van een parkeerplaats voor ladende en lossende vrachtauto's."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "E07"@nl.

imbor-term:1f26f423-b94d-4deb-b242-8cecdc650d4c a skos:Concept;
  skos:broader imbor-term:a06c1b7f-2b01-4f79-beb6-0ae3ba782556;
  skos:definition "	Punt dat is ingemeten en vervolgens gebruikt is bij en onderdeel uitmaakt van de begrenzing van BGT objecten."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Plaatsbepalingspunt"@nl.

imbor-term:1f27dae0-299d-4407-927e-f719c44ac12b a skos:Concept;
  skos:definition "Halichoerus grypus, een zeeroofdier uit de familie zeehonden. De dieren zijn van andere zeehonden te onderscheiden door hun rechte snuit. Het dier wordt 165 tot 330 cm lang. "@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Grijze zeehond"@nl.

imbor-term:1f2dfddb-a5a6-45da-a1b8-ee1e7d3c9de2 a skos:Concept;
  skos:definition "Rijstrook die behoort tot die rijstroken in een weefvak die minimaal vereist zijn om te kunnen weven."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:note "Wegvak van beperkte lengte tussen een convergentie- en een divergentiepunt waar vanaf het verkeer kan weven."@nl;
  skos:prefLabel "Weefstrook"@nl.

imbor-term:1f32a9af-31f3-4af5-a14c-354f1ee24774 a skos:Concept;
  skos:broader imbor-term:70cb0faa-0a78-4ca0-a1fe-a66865545013;
  skos:definition "Bromfietser rechtdoor."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "BW03b"@nl.

imbor-term:1f37ce11-4188-4fe9-879b-04bebd5baadc a skos:Concept;
  skos:definition "Sorex araneus, een algemene muizensoort. De vacht is meestal donkerbruin en op de buik grijzig wit. 55-85 mm lang."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Gewone bosspitsmuis"@nl.

imbor-term:1f44f2cb-f942-4a7f-8733-70d616f26d8c a skos:Concept;
