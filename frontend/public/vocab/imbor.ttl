  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Zand"@nl.

imbor-term:f5761f55-d968-4d28-b38f-280e1357bf56 a skos:Concept;
  skos:broader imbor-term:f72f0ed9-4b6c-4fdf-bb92-56f18a8d3170;
  skos:definition "Verdediging van de vooroever, ter voorkoming van het uitscheuren van de geul in het voorland. Door de vooroevers te versterken door middel van bestortingen, blijft de veiligheid en stabiliteit van de dijken gewaarborgd."@nl;
  skos:inScheme imbor-term:term-schema;
  skos:prefLabel "Vooroeververdediging"@nl.

imbor-term:f584ecc4-8c48-4494-b75d-fbbf3901be13 a skos:Concept;
