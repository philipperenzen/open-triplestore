# Copy to .env and fill in real values before `docker compose up`. docker-compose.yml requires
# these (no insecure defaults). NEVER commit the resulting .env.

# Session-token signing secret. Forgeable if weak/known — generate a unique one:
#   openssl rand -hex 32
JWT_SECRET=

# MinIO (S3 asset store) root credentials. No minioadmin/minioadmin default.
#   openssl rand -hex 16   (for each)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Bind addresses for published ports. Default 127.0.0.1 (loopback only); put a reverse proxy in
# front for production. Set to 0.0.0.0 ONLY if you intentionally expose the host port.
# TRIPLESTORE_BIND=127.0.0.1
# MINIO_BIND=127.0.0.1

# Host ports for published services. Container names/networks are already isolated per
# `docker compose` project (e.g. one per git worktree), but the host port is not — running
# a second checkout with the defaults below will fail with "port is already allocated".
# Give each concurrent checkout its own .env with distinct ports:
# TRIPLESTORE_PORT=7878
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
# OLLAMA_PORT=11434
# VLLM_PORT=8000

# Pin the MinIO image to an immutable digest in production:
#   MINIO_IMAGE=quay.io/minio/minio@sha256:<digest>

# CORS allowlist for trusted frontend origin(s), comma-separated. Empty ⇒ same-origin only.
# Use "*" to reflect ANY origin with credentials (mirror mode) — needed when a browser
# client served from an arbitrary host (e.g. the OTL viewer on http://localhost:5190)
# connects to this store. Safe here because session cookies are SameSite=Strict and the
# only cross-origin credential is the Authorization bearer token; still, prefer an
# explicit list in production.
# CORS_ORIGINS=https://viewer.example.org

# OIDC resource server (optional). Leave blank for password/PAT only.
# OIDC_ISSUER=
# OIDC_AUDIENCE=

# Outbound email (optional) — account verification, password reset, username reminders.
# Leave unset for log-only mode: every message, incl. its action link, is written to the
# server log (fine for dev). For real delivery pick ONE of the setups below (docs/auth.md).
#
# A) Bundled Postfix relay in this stack (service `mail`, enabled via the `mail` profile):
#   COMPOSE_PROFILES=mail
#   SMTP_HOST=mail
#   SMTP_TLS=none                          # relay hop stays on the private compose network
#   SMTP_FROM=Open Triplestore <no-reply@example.org>
#   MAIL_SENDER_DOMAINS=example.org        # sender domain(s) the relay accepts, space-separated
#   MAIL_HOSTNAME=mail.example.org         # HELO name; direct-MX delivery wants matching DNS/rDNS
#   # Direct-to-MX needs outbound port 25 + SPF/rDNS for this host — and Gmail/Outlook
#   # additionally require SPF or DKIM to PASS for the From domain, so mail from a domain
#   # without published DNS records is rejected or spam-foldered even when well-formed.
#   # From a laptop or an IP without mail reputation, route through a smarthost instead:
#   MAIL_RELAYHOST=[smtp.eu.mailgun.org]:587
#   MAIL_RELAYHOST_USERNAME=
#   MAIL_RELAYHOST_PASSWORD=
#   MAIL_IMAGE=boky/postfix:latest         # pin to an immutable digest in production
#
# B) External SMTP provider straight from the app (no extra service):
#   SMTP_HOST=smtp.example.org
#   SMTP_PORT=587
#   SMTP_USERNAME=
#   SMTP_PASSWORD=
#   SMTP_TLS=starttls                      # none | starttls | implicit (default from port)
#   SMTP_FROM=Open Triplestore <no-reply@example.org>
#
# Either way, make sure BASE_URL is the browser-facing origin of the deployment — it is
# the default base for emailed action links (and also mints linked-data IRIs and anchors
# the WebAuthn/passkey relying party):
#   BASE_URL=https://data.example.org
#   PUBLIC_BASE_URL=                       # optional override for the emailed links only
# Once delivery works, optionally require a verified address for password login:
#   OTS_REQUIRE_VERIFIED_EMAIL=1

# AI assistance (optional) — bring your own LLM. Point at ANY OpenAI-compatible chat
# endpoint: OpenAI, OpenRouter, Azure OpenAI, Ollama, LM Studio, vLLM, llama.cpp, or a
# self-hosted gateway. Leave LLM_GATEWAY_URL unset/unreachable to disable the AI
# features (they hide in the UI).
#   LLM_GATEWAY_URL=http://127.0.0.1:11434   # e.g. Ollama; OpenAI: https://api.openai.com
#   LLM_MODEL=llama3.1                        # model your endpoint serves (e.g. gpt-4o-mini)
#   LLM_API_KEY=                              # bearer token for hosted APIs; unset for local servers
#   LLM_SPARQL_MODEL=                         # optional per-task overrides (fall back to LLM_MODEL)
#   LLM_SHACL_MODEL=

# Bundled ollama model server (started with `docker compose --profile llm up`). Its published
# port 11434 binds to TRIPLESTORE_BIND and its browser CORS allowlist follows CORS_ORIGINS by
# default, so exposing the store also publishes the LLM on 11434 with matching CORS. Override
# either one independently (ollama has no auth — keep it on a trusted network):
#   OLLAMA_BIND=127.0.0.1                 # host bind for the 11434 port (default: TRIPLESTORE_BIND)
#   OLLAMA_ORIGINS=*                      # ollama CORS origins (default: CORS_ORIGINS); "*" = any origin
#   OLLAMA_IMAGE=ollama/ollama:latest     # pin to an immutable digest in production
#   OLLAMA_KEEP_ALIVE=1h                  # keep the model loaded between chats (big TTFT win)
#   OLLAMA_NUM_PARALLEL=2                 # concurrent generations before queueing

# Bundled vLLM server (NVIDIA GPU; `docker compose --profile llm-vllm up`). Faster than ollama
# under load thanks to automatic prefix caching of Spark's shared system prompt. Point the
# triplestore at it: LLM_GATEWAY_URL=http://vllm:8000 and LLM_MODEL=<the served model>.
#   VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct-AWQ   # HF model id (downloads on first start)
#   VLLM_MAX_MODEL_LEN=16384                  # context window (smaller = more VRAM for caching)
#   VLLM_GPU_MEM=0.90                         # fraction of VRAM vLLM may use
#   HUGGING_FACE_HUB_TOKEN=                   # only for gated models

# LLM guard & telemetry (all optional — sensible defaults):
#   LLM_RATE_LIMIT_PER_MIN=20            # per-user/IP AI request budget per minute (0 = off)
#   LLM_GUARD_INJECTION_ACTION=block     # prompt-injection heuristics: block | flag | off
#   LLM_GUARD_BLOCKLIST=                 # comma-separated phrases that always block
#   LLM_GUARD_MAX_MESSAGE_CHARS=8000     # per-message size cap
#   LLM_GUARD_MAX_MESSAGES=40            # conversation length cap
#   LLM_GUARD_MAX_TOTAL_CHARS=64000      # whole-conversation size cap
#   LLM_LOG_PREVIEW_DISABLED=            # 1 = don't store question previews in the admin log
#   LLM_LOG_RETENTION_DAYS=90            # prune admin LLM log rows after this many days

# Malware scanning of uploaded assets (optional; requires the `asset-clamav` build feature,
# which is included in `full`). Point at a ClamAV daemon's INSTREAM endpoint as host:port.
# Only an explicit virus hit rejects the upload; a scanner outage fails open. Unset = disabled.
#   CLAMAV_ADDR=127.0.0.1:3310

# Web UI: the server bundles and serves the Svelte frontend at / by default. Set
# to false for a headless, API-only deployment (SPARQL / Graph Store / REST are
# unaffected either way). Also exposed as the --serve-frontend CLI flag.
# SERVE_FRONTEND=false

# Cross-app service discovery (optional, off by default). Enable to self-register this store with
# a service registry so sibling apps / the web UI can resolve it instead of hardcoding a URL.
# A missing registry is fail-soft either way; this just makes discovery an explicit opt-in.
#   LD_DISCOVERY=true
#   LD_REGISTRY_URL=http://host.docker.internal:8500   # registry location (used only when enabled)
#   LD_REGISTRY_TOKEN=                                  # bearer; only if the registry binds non-loopback
